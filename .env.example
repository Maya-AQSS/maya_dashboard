# ─── App ──────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=
APP_URL=https://${HOST_PREFIX}dashboard-api.${DOMAIN_SUFFIX}

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dashboard_${MAYA_SLOT_DB}
DB_USERNAME=dashboard_user
DB_PASSWORD=secret

# ─── Conexión a la BD (gestionada por infra/) ─────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432

# Conexión read-only a log_mgmt_db (alertas). FPM no expone env vars
# del contenedor a $_ENV (variables_order=GPCS), así que duplicamos aquí.
LOG_MGMT_DB_HOST=maya_infra_postgres
LOG_MGMT_DB_PORT=5432
LOG_MGMT_DB_DATABASE=log_mgmt_db
LOG_MGMT_DB_USERNAME=log_mgmt_user
LOG_MGMT_DB_PASSWORD=secret

# ─── Seeding ──────────────────────────────────────────────────
DB_SEED_MODE=if-empty

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=maya_redis
REDIS_PORT=6379
REDIS_PASSWORD=secret
CACHE_STORE=redis

# ─── Keycloak / JWT (auth shared package) ─────────────────────
KEYCLOAK_URL=http://maya_auth_keycloak:8080
KEYCLOAK_REALM=${MAYA_SLOT}
KEYCLOAK_CLIENT_ID=maya-dashboard-backend
JWKS_URL=http://maya_auth_keycloak:8080/realms/${MAYA_SLOT}/protocol/openid-connect/certs
JWT_ISSUER=https://keycloak.${DOMAIN_SUFFIX}/realms/${MAYA_SLOT}
JWT_AUDIENCE=maya-dashboard-backend,maya-dashboard,maya-authorization,maya-audit,maya-dms,maya-logs

# ─── RabbitMQ (messaging shared package) ──────────────────────
RABBITMQ_HOST=maya_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/
MAYA_MESSAGING_APP=maya-dashboard
LOG_STACK=daily,rabbit
LOG_RABBIT_LEVEL=warning

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8003
FRONTEND_PORT=5475

# ─── Variables de frontend (propagadas a frontend/.env por up.sh) ────
VITE_API_URL=https://${HOST_PREFIX}dashboard-api.${DOMAIN_SUFFIX}/api/v1
VITE_KEYCLOAK_URL=https://keycloak.${DOMAIN_SUFFIX}
VITE_KEYCLOAK_REALM=${MAYA_SLOT}
VITE_KEYCLOAK_CLIENT_ID=maya-dashboard
VITE_DASHBOARD_API_URL=https://${HOST_PREFIX}dashboard-api.${DOMAIN_SUFFIX}
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}

# ─── CORS ─────────────────────────────────────────────────────
CORS_REGEX_DOMAIN=${DOMAIN_SUFFIX}
CORS_ADDITIONAL_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5476,http://localhost:5477
HOST_PREFIX=${HOST_PREFIX}
DOMAIN_SUFFIX=${DOMAIN_SUFFIX}

# FDW: BD upstream donde vive v_<app>_user_permissions (maya_auth_<slot>)
FDW_USER_PERMISSIONS_DATABASE=maya_auth_${MAYA_SLOT_DB}
# Tras migrar auth (v_portal_user_permissions): descomenta la línea siguiente.
FDW_USER_PERMISSIONS_REMOTE_VIEW=v_portal_user_permissions
