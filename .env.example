# ─── App ──────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=
APP_URL=http://maya-dashboard-api.maya.test

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dashboard
DB_USERNAME=maya
DB_PASSWORD=secret

# ─── Seeding ──────────────────────────────────────────────────
DB_SEED_MODE=if-empty

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8003
FRONTEND_PORT=5175

# ─── Variables de frontend (propagadas a frontend/.env por up.sh) ────
VITE_API_URL=http://maya-dashboard-api.maya.test/api/v1
VITE_KEYCLOAK_URL=http://keycloak.maya.test
VITE_KEYCLOAK_REALM=maya
VITE_KEYCLOAK_CLIENT_ID=maya-dashboard
VITE_DASHBOARD_API_URL=http://maya-dashboard-api.maya.test
