# ─── App ──────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=
APP_URL=http://maya_dashboard_api.localhost

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dashboard
DB_USERNAME=maya
DB_PASSWORD=secret

# ─── Odoo FDW (opcional, base técnica para perfil) ─────────────
ODOO_FDW_ENABLED=false
ODOO_FDW_SERVER=odoo_server
ODOO_FDW_HOST=
ODOO_FDW_PORT=5432
ODOO_FDW_DATABASE=odoo_db
ODOO_FDW_USERNAME=
ODOO_FDW_PASSWORD=
ODOO_FDW_SCHEMA=public

# ─── Seeding ──────────────────────────────────────────────────
DB_SEED_MODE=if-empty

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8003
FRONTEND_PORT=5175

# ─── Variables de frontend (propagadas a frontend/.env por up.sh) ────
VITE_API_URL=http://maya_dashboard_api.localhost/api/v1
VITE_KEYCLOAK_URL=http://keycloak.localhost
VITE_KEYCLOAK_REALM=maya
VITE_KEYCLOAK_CLIENT_ID=maya-dashboard
VITE_DASHBOARD_API_URL=http://maya_dashboard_api.localhost
