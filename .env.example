# ─── App ──────────────────────────────────────────────────────
APP_ENV=local
APP_KEY=
APP_URL=https://desarrollo-ceedcv-dashboard-api.192.168.2.1.nip.io

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dashboard_${MAYA_SLOT_DB}
DB_USERNAME=maya
DB_PASSWORD=secret

# ─── Seeding ──────────────────────────────────────────────────
DB_SEED_MODE=if-empty

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8003
FRONTEND_PORT=5475

# ─── Variables de frontend (propagadas a frontend/.env por up.sh) ────
VITE_API_URL=https://desarrollo-ceedcv-dashboard-api.192.168.2.1.nip.io/api/v1
VITE_KEYCLOAK_URL=https://keycloak.192.168.2.1.nip.io
VITE_KEYCLOAK_REALM=${MAYA_SLOT}
VITE_KEYCLOAK_CLIENT_ID=maya-dashboard
VITE_DASHBOARD_API_URL=https://desarrollo-ceedcv-dashboard-api.192.168.2.1.nip.io
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}
