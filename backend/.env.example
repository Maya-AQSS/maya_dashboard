APP_NAME="Maya Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://${HOST_PREFIX}dashboard-api.${DOMAIN_SUFFIX}

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,rabbit
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_RABBIT_LEVEL=warning

# ─── RabbitMQ (broker compartido en maya_infra) ───────────────
RABBITMQ_HOST=maya_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/${MAYA_SLOT_DB}
MAYA_MESSAGING_APP=maya-dashboard

# ─── Base de datos ────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432
DB_DATABASE=maya_dashboard_${MAYA_SLOT_DB}
DB_USERNAME=maya
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ─── Reverb (WebSockets — notificaciones en tiempo real) ──────
REVERB_APP_ID=maya-dashboard
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=maya_redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@maya.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

VIEW_COMPILED_PATH=/tmp/laravel-views

# ─── JWT / JWKS (maya-shared-auth-laravel) ────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/${MAYA_SLOT}/protocol/openid-connect/certs
JWT_ISSUER=https://keycloak.${DOMAIN_SUFFIX}/realms/${MAYA_SLOT}
JWT_AUDIENCE=maya-dashboard-backend,maya-audit,maya-dms,maya-logs
JWKS_CACHE_TTL=3600

# ─── Keycloak (backend-to-KC calls) ─────────────────────────
KEYCLOAK_URL=http://maya_auth_keycloak:8080
KEYCLOAK_REALM=${MAYA_SLOT}
KEYCLOAK_CLIENT_ID=maya-dashboard-backend

# ─── Log Management DB (usado por EvaluateAlertRules) ────────
# IMPORTANT: connect with the read-only role provisioned via
# database/sql/log_mgmt_readonly_role.sql. LOG_MGMT_DB_PASSWORD MUST be set —
# config/database.php throws at boot if it is empty.
LOG_MGMT_DB_HOST=maya_infra_postgres
LOG_MGMT_DB_PORT=5432
LOG_MGMT_DB_DATABASE=log_mgmt_db
LOG_MGMT_DB_USERNAME=log_mgmt_readonly
LOG_MGMT_DB_PASSWORD=

# ─── Puertos (acceso directo sin Traefik) ─────────────────────
BACKEND_PORT=8003
FRONTEND_PORT=5175

# ─── Slot context (materializadas por envsubst en up-common.sh) ───────────────
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}
HOST_PREFIX=${HOST_PREFIX}
DOMAIN_SUFFIX=${DOMAIN_SUFFIX}
